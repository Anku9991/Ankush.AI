# Ankush.AI Environment Configuration

# Server Settings
PORT=3001
NODE_ENV=development

# Security
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,https://ankush.ai

# Email Settings (Gmail)
# 1. Go to Google Account -> Security -> 2-Step Verification
# 2. Scroll to bottom -> App Passwords
# 3. Create a new "Mail" password for your server
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Notification Recipient (defaults to EMAIL_USER if empty)
NOTIFY_EMAIL=Ankush.AI2026@gmail.com
