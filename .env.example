# ─── Ankush.AI Backend — Environment Variables ───────────────
# Copy this file to .env and fill in your values

PORT=3001

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://ankush.ai,https://www.ankush.ai

# Gmail credentials (use an App Password, not your real password)
# How to get: myaccount.google.com → Security → 2-Step Verification → App passwords
EMAIL_USER=your.gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Where to send lead notifications
NOTIFY_EMAIL=Ankush.AI2026@gmail.com

# Admin key for GET /api/leads (change this to something long and random!)
ADMIN_KEY=change-this-to-a-strong-secret-key-123
